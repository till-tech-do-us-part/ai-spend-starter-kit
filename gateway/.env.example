# Generate with `echo "sk-$(openssl rand -hex 24)"`.
LITELLM_MASTER_KEY=sk-REPLACE-ME
# Generate with `echo "sk-salt-$(openssl rand -hex 24)"`; NEVER change it after first boot because it encrypts stored keys in Postgres.
LITELLM_SALT_KEY=sk-salt-REPLACE-ME
# Generate with `openssl rand -hex 16`.
POSTGRES_PASSWORD=REPLACE-ME
# Use hex-only random material for all three generated secrets. Values must contain no `$`, quotes, or spaces because Compose interpolates unquoted .env values.
# Required for the quickstart; create a key at https://aistudio.google.com/apikey.
GEMINI_API_KEY=REPLACE-ME
# Optional — only for the opt-in cross-provider review recipe in config.yaml. Gemini is the default provider.
# GROQ_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Optional. Without these overrides, dashboard login is admin / LITELLM_MASTER_KEY.
# UI_USERNAME=team-admin
# UI_PASSWORD=choose-a-strong-password
# Optional. Defaults to localhost. Override only with a tailnet/VPN host address, never a public interface.
# LITELLM_BIND_HOST=127.0.0.1
