# Generate an admin API key that starts with sk-; a password manager can make the random suffix.
LITELLM_MASTER_KEY=sk-REPLACE-ME
# Generate one long random value; NEVER change it after first boot because it encrypts stored keys in Postgres.
LITELLM_SALT_KEY=sk-salt-REPLACE-ME
# Generate a strong local database password with a password manager.
POSTGRES_PASSWORD=REPLACE-ME
# Choose the username used to log in to the LiteLLM dashboard.
UI_USERNAME=REPLACE-ME
# Generate the password used to log in to the LiteLLM dashboard.
UI_PASSWORD=REPLACE-ME
# Required for the quickstart; create a key at https://aistudio.google.com/apikey.
GEMINI_API_KEY=REPLACE-ME
# OPTIONAL: create at https://console.anthropic.com/ to activate the review tier.
ANTHROPIC_API_KEY=REPLACE-ME
# OPTIONAL: create at https://platform.openai.com/api-keys for the commented OpenAI recipe.
OPENAI_API_KEY=REPLACE-ME
